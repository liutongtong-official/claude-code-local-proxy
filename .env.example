# Local server overrides.
# Point Claude Code to this local proxy:
#   export ANTHROPIC_BASE_URL=http://127.0.0.1:8787
# PROXY_LISTEN_HOST=127.0.0.1
# PROXY_LISTEN_PORT=8787
# LOG_FILE=logs/claude-code-local-proxy.log
# LOG_LEVEL=INFO

# Request sanitizer overrides.
# SANITIZER_MODE=normalize
# Enable only the sanitizer rules you want to run.
# SANITIZER_RULES=date-marker,timezone-marker
# Rewrite Claude Code timezone markers in JSON request bodies to this IANA timezone.
# SANITIZER_TIMEZONE=America/Los_Angeles

# Upstream API overrides.
# Set this only when using a channel/proxy, and do not point it back at this local proxy.
# UPSTREAM_BASE_URL=https://your-channel.example.com
# UPSTREAM_TIMEOUT_SECONDS=300

# Egress guard overrides.
# EGRESS_GUARD_ENABLED=true
# EGRESS_GUARD_MODE=country-code
# EGRESS_GUARD_FIXED_IP=203.0.113.10
# EGRESS_GUARD_BLOCKED_COUNTRY_CODES="CN,HK,MO,TW"
# EGRESS_GUARD_FAIL_CLOSED=true
# EGRESS_GUARD_PROVIDER_TIMEOUT_SECONDS=5
# EGRESS_GUARD_PUBLIC_IP_CACHE_SECONDS=0
# EGRESS_GUARD_IP_REGION_CACHE_SECONDS=86400
