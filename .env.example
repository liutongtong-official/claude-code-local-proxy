# Common settings
# Point Claude Code to this local proxy:
#   export ANTHROPIC_BASE_URL=http://127.0.0.1:8787
PROXY_LISTEN_HOST=127.0.0.1
PROXY_LISTEN_PORT=8787

# Real upstream Anthropic-compatible endpoint. Defaults to https://api.anthropic.com.
# Set this only when using a channel/proxy, and do not point it back at this local proxy.
# UPSTREAM_BASE_URL=https://your-channel.example.com

# Sanitizer mode: off | observe | normalize
SANITIZER_MODE=normalize

# Advanced settings — usually no need to change.
# UPSTREAM_TIMEOUT_SECONDS=300
# LOG_LEVEL=INFO
